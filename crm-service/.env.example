# CRM Service — copy to .env and fill in values

# Anthropic API
ANTHROPIC_API_KEY=your_key_here

# Service URLs (set after Railway deployment)
CHANNEL_SERVICE_URL=https://your-channel-service.railway.app
CRM_CALLBACK_URL=https://your-crm-service.railway.app
FRONTEND_URL=https://your-frontend.vercel.app

# Server
PORT=3000

# Database (Railway auto-sets this for persistent volume)
DB_PATH=./data/cohortai.db
